import java.util.*;

public class Main {
    public static void main(String[] args) {
      Scanner sc=new Scanner(System.in);
      Node root=null;
      int n=sc.nextInt();
      for(int i=0;i<n;i++){
        int data=sc.nextInt();
       root =build(root,data);
      }
     pre(root);
     level(root);
    }
    public static Node build(Node root,int data){
      if(root==null) return new Node(data);
      if(data<root.data) root.left=build(root.left,data);
      if(data>root.data) root.right=build(root.right,data);
      return root;
    }
    public static void pre(Node root){
      if(root==null)return;
      System.out.print(root.data+" ");
      pre(root.left);
      pre(root.right);
    }
///level order traversal///

 public static void level(Node root){
      Queue <Node>q=new LinkedList<>();
       q.offer(root);
      while(!q.isEmpty()){
        Node t=q.poll();
      System.out.print(t.data+" ");
        if(t.left!=null)
        q.offer(t.left);
        if(t.right!=null)
        q.offer(t.right);
      }
    }
}
class Node{
  int data;
  Node left,right;
  Node(int data){
    this.data=data;
    left=right=null;
  }
}

